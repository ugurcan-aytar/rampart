{
  "name": "@ugurcan-aytar/backstage-plugin-rampart",
  "version": "0.1.0",
  "private": true,
  "description": "rampart Backstage frontend plugin — incident dashboard, blast radius, SSE live stream.",
  "license": "MIT",
  "author": "Uğurcan Aytar <aytarugurcan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ugurcan-aytar/rampart.git",
    "directory": "backstage/plugins/rampart"
  },
  "backstage": {
    "role": "frontend-plugin"
  },
  "configSchema": "config.d.ts",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "gen:api": "openapi-typescript ../../../schemas/openapi.yaml -o src/api/gen/schema.ts",
    "typecheck": "tsc --noEmit",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test --watch=false --passWithNoTests",
    "dev": "backstage-cli package start --config app-config.yaml"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.9",
    "@backstage/core-plugin-api": "^1.10.0",
    "@backstage/plugin-catalog-react": "^2.1.4",
    "@backstage/theme": "^0.7.3",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "dagre": "0.8.5",
    "reactflow": "11.11.4",
    "recharts": "^2.15.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@backstage/app-defaults": "1.7.7",
    "@backstage/cli": "^0.34.6",
    "@backstage/core-app-api": "1.20.0",
    "@backstage/dev-utils": "1.1.22",
    "@types/dagre": "^0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "openapi-typescript": "7.13.0",
    "puppeteer-core": "^24.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "typescript": "6.0.3"
  }
}
