{
  "name": "@ugurcan-aytar/backstage-plugin-rampart-backend",
  "version": "0.1.0",
  "private": true,
  "description": "rampart Backstage backend plugin — proxies /api/rampart/* to the engine and runs catalog sync.",
  "license": "MIT",
  "author": "Uğurcan Aytar <aytarugurcan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ugurcan-aytar/rampart.git",
    "directory": "backstage/plugins/rampart-backend"
  },
  "backstage": {
    "role": "backend-plugin"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "typecheck": "tsc --noEmit",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test --watch=false --passWithNoTests"
  },
  "devDependencies": {
    "@backstage/cli": "^0.29.0",
    "@types/express": "^4.17.0",
    "@types/node": "22.5.0",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "@backstage/backend-defaults": "^0.12.2",
    "@backstage/backend-plugin-api": "^1.0.2",
    "@backstage/catalog-client": "^1.7.0",
    "@backstage/config": "^1.2.0",
    "@backstage/errors": "^1.2.4",
    "express": "^4.21.0"
  }
}
