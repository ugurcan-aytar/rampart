# Synthetic benchmark lockfiles, produced by
# `go run ./cmd/gen-lockfile-fixture -packages N -output testdata/lockfiles/<name>`.
# The small fixtures (axios-compromise, simple-webapp, …) are committed
# for the parity test; the large ones here are not — they grow to tens
# of MiB and regenerate deterministically from the same seed.
/engine/testdata/lockfiles/medium-200-pkgs.json
/engine/testdata/lockfiles/medium-2k-pkgs.json
/engine/testdata/lockfiles/large-20k-pkgs.json
/engine/testdata/lockfiles/huge-100k-pkgs.json
